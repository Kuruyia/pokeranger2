Arm9
{
	Static main.sbin
	OverlayDefs main_defs.sbin
	OverlayTable main_table.sbin
	Nef main.nef
}

Arm7
{
	Static "$(ARM7)"
	OverlayDefs "$(ARM7_DEFS)"
}

Property
{
	RomHeaderTemplate "$(HEADER_TEMPLATE)"
	TitleName "$(TITLE_NAME)"
	MakerCode "01"
	RemasterVersion 0
	RomSpeedType 1TROM
	RomSize 512M
	RomFootPadding TRUE
	BannerFile "$(BNR)"
}

