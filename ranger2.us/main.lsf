    Library MSL_C_NITRO_Ai_LE.a
    Library MSL_Extras_NITRO_Ai_LE.a
    Library MSL_CPP_NITRO_Ai_LE.a
    Library FP_fastI_v5t_LE.a
    Library NITRO_Runtime_Ai_LE.a
}

Autoload ITCM
{
    Address 0x01FF8000
    Library libos.a (.itcm)
    Library libmi.a (.itcm)
}

Autoload DTCM
{
    Address 0x027E0000
    Library libos.a (.dtcm)
}

